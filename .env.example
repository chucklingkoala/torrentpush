# ── Required ──────────────────────────────────────────────────────────────────
# URL of your qBittorrent WebUI — no trailing slash.
# If qBittorrent is on the same Docker network, use its service name.
QB_HOST=http://qbittorrent:8080

# qBittorrent WebUI credentials
QB_USERNAME=admin
QB_PASSWORD=adminadmin

# ── Optional ──────────────────────────────────────────────────────────────────
# Absolute path to watch for .torrent files.
# Docker: must match the right side of the volume mount in docker-compose.yml.
# systemd: set this to the actual directory on your filesystem.
WATCH_DIR=/data/torrents/inbox

# Override the download save path inside qBittorrent (leave blank for QB default)
QB_SAVE_PATH=

# Assign a category to every uploaded torrent (leave blank to skip)
QB_CATEGORY=

# Comma-separated tags to assign (leave blank to skip)
QB_TAGS=

# Set to "true" to add torrents in paused state
QB_ADD_PAUSED=false

# Seconds to wait between upload retry attempts
RETRY_DELAY=5

# Maximum number of upload attempts before a file is moved to failed/
MAX_RETRIES=3
